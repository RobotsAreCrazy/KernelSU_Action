CONFIG_ENV=config.env

# Your Samsung A9+ Source
KERNEL_SOURCE=https://github.com/RobotsAreCrazy/kernel_a9plus_source
KERNEL_SOURCE_BRANCH=main
KERNEL_CONFIG=gta9p_eur_openx_defconfig
KERNEL_IMAGE_NAME=Image.gz
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=false
EXTRA_CMDS:LD=ld.lld

# Clang - Using the stable r450784d version
USE_CUSTOM_CLANG=false
CLANG_BRANCH=master-kernel-build-2022
CLANG_VERSION=r450784e

CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

# GCC - Keep enabled for 5.4 kernels
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true

# KernelSU-Next Setup (The "Next" version is better for modern Samsung)
ENABLE_KERNELSU=true
CUSTOM_KSU_REPO=https://github.com/KernelSU-Next/KernelSU-Next
KERNELSU_TAG=next

# Configuration - SusFS and Kprobes are required for stealth
DISABLE-LTO=false
DISABLE_CC_WERROR=true
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true
ENABLE_SUSFS=true
SUSFS_VERSION=kernel-5.4

# Ccache for faster building
ENABLE_CCACHE=true

# DTBO - Not needed for standard boot.img builds on A9+
NEED_DTBO=false

EXTRA_CMDS:KCONFIG_CONFIG_SET=CONFIG_RTC_LIB=y
